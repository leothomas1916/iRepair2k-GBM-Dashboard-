# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_CLIENT_ID: Required for Google OAuth
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# GOOGLE_CLIENT_SECRET: Required for Google OAuth
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps Platform APIs, places search, and directions
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_PLATFORM_KEY"

# CRON_SECRET: Secret key to secure the automated cron job endpoint (/api/cron)
CRON_SECRET="YOUR_CRON_SECRET"

# GOOGLE_REFRESH_TOKEN: Google OAuth Refresh Token to authorize Google Business Profile automation without user interaction
GOOGLE_REFRESH_TOKEN="YOUR_GOOGLE_REFRESH_TOKEN"

